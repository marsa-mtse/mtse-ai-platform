# MTSE Marketing Engine - Secrets Configuration
# Rename this file to 'secrets.toml' inside the '.streamlit' folder

# Google Gemini API Key (FREE Tier - Recommended)
# Get it at https://aistudio.google.com/
GOOGLE_API_KEY = "your-google-api-key-here"

# OpenAI API Key (Optional fallback)
OPENAI_API_KEY = "your-openai-api-key-here"

# Stripe Secret Key (Optional - for billing)
# STRIPE_SECRET_KEY = "sk_test_..."

# App Settings
DEBUG = false
